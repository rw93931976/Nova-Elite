{
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                }
            ]
        },
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/bridge-vps/(.*)",
            "destination": "http://31.220.59.237:3505/$1"
        },
        {
            "source": "/((?!assets/|rescue.html|icon.png|manifest.json|manifest.webmanifest).*)",
            "destination": "/index.html"
        }
    ]
}